{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://soundscript.net/schemas/wordbank/corpus-manifest.schema.json",
  "title": "SoundScript Corpus Manifest",
  "type": "object",
  "required": ["id", "version", "status", "locales", "engineCompatibility"],
  "properties": {
    "$schema": { "type": "string" },
    "id": { "type": "string", "pattern": "^\\d{4}\\.\\d{2}$" },
    "version": { "type": "integer", "minimum": 0 },
    "status": { "enum": ["pilot", "draft", "released"] },
    "description": { "type": "string" },
    "released": { "type": "string", "format": "date" },
    "locales": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["code", "path", "lemmaFile"],
        "properties": {
          "code": { "type": "string" },
          "path": { "type": "string" },
          "lemmaFile": { "type": "string" },
          "pilotFile": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "engineCompatibility": {
      "type": "object",
      "required": ["soundscriptMin", "wordbankMin"],
      "properties": {
        "soundscriptMin": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
        "wordbankMin": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
