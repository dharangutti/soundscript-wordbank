{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://soundscript.net/schemas/wordbank/manifest.schema.json",
  "title": "SoundScript Wordbank Manifest",
  "type": "object",
  "required": ["name", "version", "schemaVersion", "defaultLocale", "locales"],
  "properties": {
    "$schema": { "type": "string" },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "description": { "type": "string" },
    "defaultLocale": { "type": "string", "pattern": "^[a-z]{2}(-[A-Z]{2})?$" },
    "locales": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["code", "name", "path"],
        "properties": {
          "code": { "type": "string" },
          "name": { "type": "string" },
          "path": { "type": "string" }
        }
      }
    },
    "source": { "type": "object" }
  },
  "additionalProperties": false
}
