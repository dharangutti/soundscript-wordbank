{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://soundscript.net/schemas/wordbank/lemmas.schema.json",
  "title": "SoundScript Corpus Lemmas",
  "type": "object",
  "required": ["corpusId", "locale", "version", "status", "entries"],
  "properties": {
    "$schema": { "type": "string" },
    "corpusId": { "type": "string", "pattern": "^\\d{4}\\.\\d{2}$" },
    "locale": { "type": "string" },
    "version": { "type": "integer", "minimum": 0 },
    "status": { "enum": ["pilot", "draft", "released"] },
    "description": { "type": "string" },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["lemma"],
        "properties": {
          "lemma": { "type": "string", "minLength": 1 },
          "license": { "enum": ["CC0-1.0", "CC-BY-4.0"] },
          "source": { "type": "string" },
          "attribution": { "type": "string" },
          "audio": {
            "type": "string",
            "description": "Path relative to corpus root, e.g. audio/en/hello.wav"
          },
          "trimStartMs": { "type": "number", "minimum": 0 },
          "trimEndMs": { "type": "number", "minimum": 0 },
          "gain": { "type": "number", "minimum": 0, "maximum": 4 },
          "pitchSemitones": { "type": "number", "minimum": -24, "maximum": 24 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
