{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://soundscript.net/schemas/wordbank/ci-fixtures.schema.json",
  "title": "SoundScript CI Word Fixtures",
  "type": "object",
  "required": ["version", "fixtures"],
  "properties": {
    "$schema": { "type": "string" },
    "version": { "type": "integer", "minimum": 1 },
    "description": { "type": "string" },
    "fixtures": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "array",
        "minItems": 50,
        "maxItems": 50,
        "items": { "type": "string", "minLength": 1 }
      }
    }
  },
  "additionalProperties": false
}
