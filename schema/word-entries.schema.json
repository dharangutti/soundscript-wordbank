{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://soundscript.net/schemas/wordbank/word-entries.schema.json",
  "title": "Word Entries",
  "type": "object",
  "required": ["version", "locale", "entries"],
  "properties": {
    "$schema": { "type": "string" },
    "version": { "type": "integer", "minimum": 1 },
    "locale": { "type": "string" },
    "description": { "type": "string" },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["word"],
        "properties": {
          "word": { "type": "string", "minLength": 1 },
          "syllables": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "stress": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["primary", "secondary", "unstressed"]
            }
          },
          "category": {
            "type": "string",
            "enum": ["content", "function"]
          }
        }
      }
    }
  },
  "additionalProperties": false
}
