{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://soundscript.net/schemas/wordbank/grapheme-rules.schema.json",
  "title": "Grapheme Rules",
  "type": "object",
  "required": ["version", "locale", "digraphs", "singleLetters"],
  "properties": {
    "$schema": { "type": "string" },
    "version": { "type": "integer", "minimum": 1 },
    "locale": { "type": "string" },
    "description": { "type": "string" },
    "digraphs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["grapheme", "phonemes"],
        "properties": {
          "grapheme": { "type": "string", "minLength": 1 },
          "phonemes": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "singleLetters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["letter", "phonemes"],
        "properties": {
          "letter": { "type": "string", "minLength": 1, "maxLength": 1 },
          "phonemes": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  },
  "additionalProperties": false
}
